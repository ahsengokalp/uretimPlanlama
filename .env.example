# Ollama API address used for optional AI agenda/comment generation.
# Local default:
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name to use, for example: llama3.1, mistral, qwen2.5
OLLAMA_MODEL=your-model-name

# Flask bind settings.
# Use 0.0.0.0 to listen on all network interfaces.
APP_HOST=0.0.0.0
APP_PORT=5053

# PostgreSQL settings used only for manual data-entry persistence.
DB_HOST=172.16.49.50
DB_PORT=5432
DB_NAME=dokumhanerapor
DB_USER=dokumhane_user
DB_PASS=your-password
